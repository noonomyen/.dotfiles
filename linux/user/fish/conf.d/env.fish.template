# Environment variables configuration
if status is-interactive
    # Set FZF default command to use fd (ignores gitignore, fast search)
    set -gx FZF_DEFAULT_COMMAND "fd --type f --hidden --exclude .git"

    # Load catppuccin theme for FZF
    source $__fish_config_dir/fzf-catppuccin/themes/catppuccin-fzf-mocha.fish

    # Append modern layout and custom keybindings to FZF_DEFAULT_OPTS
    set -gx FZF_DEFAULT_OPTS "$FZF_DEFAULT_OPTS --height 45% --layout=reverse --border=rounded --info=inline --margin=1 --padding=1 --prompt='__NERDFONT(F002)__ ' --pointer='__NERDFONT(F460)__' --marker='__NERDFONT(F42E)__ ' --bind 'ctrl-backspace:backward-kill-word,ctrl-h:backward-kill-word,?:toggle-preview'"
end
